{
    "name": "taskmanager/backend",
    "description": "PHP MVC backend for a Trello-like task management system",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.8",
        "cboden/ratchet": "^0.4.4",
        "react/event-loop": "^1.5",
        "react/socket": "^1.14",
        "psr/log": "^3.0",
        "psr/http-message": "^2.0",
        "psr/container": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        } 
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "ws": "php src/WebSocket/server.php",
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "license": "MIT"
}